use eyre::{ContextCompat, Result};
use twilight_model::{
    application::interaction::{
        application_command::CommandData, message_component::MessageComponentInteractionData,
        modal::ModalInteractionData,
    },
    channel::Message,
    guild::{PartialMember, Permissions},
