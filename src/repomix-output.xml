        "pagination_page" => handle_pagination_modal(ctx, modal).await,
        _ => return error!("unknown modal `{name}`: {modal:#?}"),
    };

    if let Err(err) = res.with_context(|| format!("failed to process modal `{name}`")) {
        error!("{err:?}");
    }
}
