
#THIS EXAMPLE FILE WORKED FOR MY SYSTEM, DONT FORGET TO ADD TLS CERTS OTHERWISE GG
#also replace any domains for yours, as replays.insertdomainname.be is my domain
#---------------------------------------------------------------------------------#

(cf_tls) {
    tls /path/to/privkey.pem /path/to/privkey.key
}

(standard_perf) {
    encode zstd gzip
}

replays.insertdomainname.be {
    root * /path/to/replay/upload
    #tls force_automate ----> does not work with discord embedder
    log {
        output file /var/log/caddy/access.log
    }
    #redirect /watch/filename.mp4 → /watch/filename (strip .mp4 from the URL Discord sees)
    @watchmp4 path_regexp watchmp4 ^(/watch/.+)\.mp4$
    redir @watchmp4 {re.watchmp4.1} 301

    #serve watch page, using path_regexp to reconstruct .mp4 in og:video
    @watchpage path_regexp watchpage ^/watch/(.+)$
    handle @watchpage {
        header Content-Type "text/html; charset=utf-8"
        header Cache-Control "no-store"
        respond `<!DOCTYPE html>
<head>
    <meta property="og:title" content="^^^^^^^^^^^^^^^^^^^^^^" />
    <meta property="og:description" content="Rendered osu! replay video" />
    <meta property="og:site_name" content="Replay Server" />
    <meta property="og:type" content="video.other" />
    <meta property="og:image" content="https://replays.insertdomainname.be/{re.watchpage.1}.jpg" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="720" />
    <meta property="og:url" content="https://replays.insertdomainname.be/watch/{re.watchpage.1}" />
    <meta property="og:video" content="https://replays.insertdomainname.be/{re.watchpage.1}.mp4" />
    <meta property="og:video:url" content="https://replays.insertdomainname.be/{re.watchpage.1}.mp4" />
    <meta property="og:video:type" content="video/mp4" />
    <meta property="og:video:width" content="1280" />
    <meta property="og:video:height" content="720" />
    <meta name="twitter:card" content="player">
    <meta name="twitter:player" content=https://replays.insertdomainname.be/{re.watchpage.1}.mp4" />
    <meta name="theme-color" content="#96DFE3" />
</head>
<body style="margin:0; background:#1f1f1f; color:#f5f5f5; text-align:center;">
    <video controls autoplay style="width:100%; height:fit-content; margin-left:auto; margin-right:auto;">
        <source src="/{re.watchpage.1}.mp4" type="video/mp4">
    </video>
    <div>
    <a
  href="https://replays.insertdomainname.be/{re.watchpage.1}.mp4"
  download
  style="
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:14px 22px;
    border-radius:14px;
    background:#2d2d2d;
    color:#f5f5f5;
    text-decoration:none;
    font-weight:700;
    font-size:16px;
    border:1px solid rgba(255,255,255,0.12);
    box-shadow:0 10px 30px rgba(0,0,0,0.3);
  "
>
  Download Replay
</a>
    </div>
</body>` 200
    }

    handle /upload* {
        #here is the port for upload handler
        reverse_proxy localhost:5555 {
            header_up X-Real-IP {http.request.header.CF-Connecting-IP}
        }
    }

    file_server
    
    import cf_tls
    import standard_perf
}